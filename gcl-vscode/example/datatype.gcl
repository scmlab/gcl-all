{:  
    data B = T | F 

    x : B
    x = T

    not : B -> B 
    not x = case x of 
          T -> F 
          F -> T

    data Maybe = Just B | Nothing

    isJust : Maybe -> B 
    isJust x = case x of
        Nothing -> F 
        Just a -> T

    even : Int -> B
    even a = T
    even n = odd (n - 1)

    odd : Int -> B
    odd a = F
    odd n = even (n - 1)
:}


{ True }
