{:  
    data B = T | F

    x : B
    x = T

    not : B -> B 
    not x = case x of 
          T -> F 
          F -> T

    data Maybe = Just B | Nothing

    isJust : Maybe -> B 
    isJust x = case x of
        Nothing -> not F
        Just a -> not T

    even : Int -> B
    even a = isJust (Just x)
    even n = odd (n - 1)

    odd : Int -> B
    odd a = isJust Nothing
    odd n = even (n - 1)
:}


{ True }
