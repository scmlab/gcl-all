{
  "name": "gcl-vscode",
  "displayName": "gcl-vscode",
  "description": "An Interactive Formal Verification tool for Guarded Command Language",
  "publisher": "scmlab",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scmlab/gcl-all"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gcl",
        "extensions": [
          ".gcl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gcl",
        "scopeName": "source.gcl",
        "path": "./syntaxes/gcl.tmGrammar.json"
      }
    ],
    "commands": [
      {
        "command": "gcl.reload",
        "title": "Reload",
        "category": "GCL"
      },
      {
        "command": "gcl.refine",
        "title": "Refine",
        "category": "GCL"
      },
      {
        "command": "gcl.restartServer",
        "title": "Restart GCL Server",
        "category": "GCL"
      },
      {
        "command": "gcl.debug",
        "title": "GCL Debug",
        "category": "GCL"
      }
    ],
    "keybindings": [
      {
        "command": "gcl.reload",
        "key": "ctrl+c ctrl+l",
        "when": "!editorHasSelection && editorTextFocus"
      },
      {
        "command": "gcl.refine",
        "key": "ctrl+c ctrl+r",
        "when": "!editorHasSelection && editorTextFocus"
      },
      {
        "command": "gcl.debug",
        "key": "ctrl+c ctrl+/",
        "when": "editorTextFocus"
      }
    ],
    "configuration": [
      {
        "title": "gcl-vscode",
        "properties": {
          "gcl-vscode.gclPath": {
            "type": "string",
            "default": "gcl",
            "description": "Location of the `gcl` LSP executable"
          },
          "gcl-vscode.trace.server": {
            "type": "string",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "verbose",
            "description": "Traces the communication between VS Code and the GCL language server. The 'gcl-vscode' prefix matches the Language Client ID (which happens to be the same as the extension ID), enabling vscode-languageclient to automatically apply this setting without requiring manual code."
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "package": "vsce package --skip-license --no-dependencies",
    "compile": "pnpm run typecheck && pnpm node esbuild.cjs --prod",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.cjs --watch",
    "watch:tsc": "tsc --watch --noEmit -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts",
    "format": "prettier . --write",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "vscode-languageclient": "^9.0.1"
  }
}
