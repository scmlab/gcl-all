// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    // for VS Code users who forgot to run npm install
    {
      "label": "npm-install",
      // "type": "npm" but actually runs `pnpm install`:
      // VS Code's "npm.packageManager" defaults to "auto", which detects the
      // lockfile (pnpm-lock.yaml here) and uses the matching package manager.
      "type": "npm",
      "script": "install",
      "options": {
        "env": {
          // skip corepack's interactive prompt when downloading pnpm
          "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0"
        }
      }
    },
    {
      "label": "npm-run-watch",
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["npm-install"]
    }
  ]
}
